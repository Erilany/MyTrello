{
  "name": "mytrello",
  "version": "0.1.0",
  "description": "Application de gestion de projets à 3 niveaux avec intégration Outlook, Gmail et commandes vocales",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"npm run react:dev\" \"npm run electron:dev\"",
    "react:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "electron": "electron .",
    "db:init": "node scripts/db-init.js",
    "db:reset": "node scripts/db-reset.js",
    "db:migrate": "node scripts/db-migrate.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\"",
    "env:check": "node scripts/check-env.js"
  },
  "keywords": [
    "project-management",
    "trello-like",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "lucide-react": "^0.294.0",
    "date-fns": "^3.0.6",
    "framer-motion": "^10.16.16",
    "better-sqlite3": "^9.2.2",
    "electron-store": "^8.1.0",
    "@azure/msal-node": "^2.6.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "googleapis": "^128.0.0",
    "google-auth-library": "^9.0.0",
    "uuid": "^9.0.1",
    "clsx": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "electron": "^28.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.2",
    "@playwright/test": "^1.40.0"
  }
}
